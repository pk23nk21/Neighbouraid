    "eslint-plugin-react-refresh": "^0.4.5",
    "fake-indexeddb": "^5.0.2",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitest": "^2.1.9"
