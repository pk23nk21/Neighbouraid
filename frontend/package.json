{
  "name": "neighbouraid-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:copy": "npm run build && npx cap copy",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:doctor": "npx cap doctor",
    "mobile:add:android": "npx cap add android",
    "mobile:open:android": "npx cap open android",
    "mobile:android": "npm run mobile:sync && npx cap open android",
    "mobile:add:ios": "npx cap add ios",
    "mobile:open:ios": "npx cap open ios",
    "mobile:ios": "npm run mobile:sync && npx cap open ios",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
