# Anything here is excluded from the Docker build context.
# Critical: node_modules from the host (Windows) would overwrite the
# linux binaries that `npm ci` installs inside the Alpine build stage,
# causing `sh: vite: Permission denied` because executable bits are
# lost on NTFS.
node_modules
dist
.vite
.env
.env.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
.git
.gitignore
.dockerignore
Dockerfile
