# Copy this file to .env and fill in your values.

# -----------------------------------------------------------------------
# Backend — required
# -----------------------------------------------------------------------

# Change for production. `openssl rand -hex 32` generates a fresh value.
JWT_SECRET=joerfgnkejndfjkenjkgnmeklfvdg

# MongoDB connection string. Defaults to localhost; for Atlas use the
# mongodb+srv://... URI from the cluster's "Connect" button.
MONGO_URL=mongodb://localhost:27017/neighbouraid

# -----------------------------------------------------------------------
# Backend — optional
# -----------------------------------------------------------------------

# Skip the 1.6 GB HuggingFace model load (use the keyword-heuristic fallback).
# Set to 1 on small VMs / CI / dev. Set to 0 on prod with ≥2 GB RAM.
NA_DISABLE_AI_MODEL=1

# Comma-separated extra CORS origins. The wildcard regex already covers
# *.vercel.app and *.onrender.com — only set this for custom domains.
# FRONTEND_ORIGINS=https://app.example.com,https://staging.example.com

# Optional outbound webhook fired on every new alert. Designed for n8n,
# Zapier, Make, or a custom worker — point this at a webhook trigger and
# the automation can fan out to Slack/WhatsApp/SMS/email. Leave empty
# (or unset) to disable. Fire-and-forget — alert creation never blocks
# on the webhook.
# ALERT_WEBHOOK_URL=https://n8n.example.com/webhook/neighbouraid
# ALERT_WEBHOOK_TIMEOUT_SECONDS=4

# Shared secret for the inbound WhatsApp webhook (POST /api/inbound/whatsapp).
# The gateway must include this in the `X-Inbound-Token` header. Empty
# disables the route (returns 503).
# INBOUND_TOKEN=

# -----------------------------------------------------------------------
# Frontend — only needed if backend runs on a different host
# -----------------------------------------------------------------------

# Absolute backend URL in production. Empty = same-origin (Vite proxies in dev).
VITE_API_URL=

# Absolute backend WebSocket URL in production. Use wss:// behind TLS.
VITE_WS_URL=

# -----------------------------------------------------------------------
# Optional model auth (gated HF models, rare for this project)
# -----------------------------------------------------------------------
# HF_TOKEN=your_huggingface_token_here
